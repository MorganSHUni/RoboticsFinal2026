{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain = Brain()\n\n# Robot configuration code\nbrain_inertial = Inertial()\nleft_drive_smart = Motor(Ports.PORT6, False)\nright_drive_smart = Motor(Ports.PORT10, True)\ndrivetrain = SmartDrive(left_drive_smart, right_drive_smart, brain_inertial, 259.34, 320, 40, MM, 1)\ncolour_sensor = Optical(Ports.PORT8)\n\n\n# Wait for sensor(s) to fully initialize\nwait(100, MSEC)\n\n# generating and setting random seed\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    xaxis = brain_inertial.acceleration(XAXIS) * 1000\n    yaxis = brain_inertial.acceleration(YAXIS) * 1000\n    zaxis = brain_inertial.acceleration(ZAXIS) * 1000\n    systemTime = brain.timer.system() * 100\n    urandom.seed(int(xaxis + yaxis + zaxis + systemTime)) \n\n# Initialize random seed \ninitializeRandomSeed()\n\n\n# Color to String Helper\ndef convert_color_to_string(col):\n    if col == Color.RED:\n        return \"red\"\n    if col == Color.GREEN:\n        return \"green\"\n    if col == Color.BLUE:\n        return \"blue\"\n    if col == Color.WHITE:\n        return \"white\"\n    if col == Color.YELLOW:\n        return \"yellow\"\n    if col == Color.ORANGE:\n        return \"orange\"\n    if col == Color.PURPLE:\n        return \"purple\"\n    if col == Color.CYAN:\n        return \"cyan\"\n    if col == Color.BLACK:\n        return \"black\"\n    if col == Color.TRANSPARENT:\n        return \"transparent\"\n    return \"\"\nvexcode_initial_drivetrain_calibration_completed = False\ndef calibrate_drivetrain():\n    # Calibrate the Drivetrain Inertial\n    global vexcode_initial_drivetrain_calibration_completed\n    sleep(200, MSEC)\n    brain.screen.print(\"Calibrating\")\n    brain.screen.next_row()\n    brain.screen.print(\"Inertial\")\n    brain_inertial.calibrate()\n    while brain_inertial.is_calibrating():\n        sleep(25, MSEC)\n    vexcode_initial_drivetrain_calibration_completed = True\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n\n\n# Calibrate the Drivetrain\ncalibrate_drivetrain()\n\n#endregion VEXcode Generated Robot Configuration\n# ------------------------------------------\n# \n# \tProject:      VEXcode Project\n#\tAuthor:       VEX\n#\tCreated:\n#\tDescription:  VEXcode EXP Python Project\n# \n# ------------------------------------------\n\n# Library imports\nimport time\n\n# Begin project code\n\n# ------------------------------------------\n# VARIABLES\n# ------------------------------------------\n\n    # STATIONS\n# tracks where the PDR is currently, \n# updated whenever a station is reached, regardless of whether it is the goal or not\ncurrentStation = -1\n\n# tracks where the PDR was when it started moving to find the goal\n# only assigned at start of journey\noriginalStation = -1\n\n# The station the user has chosen\ngoalStation = -1\n\n# counts the number of stations that have passed\nstationCounter = 0\n\n    # EVENTS\n# used to determine the state of the PDR\n# whether it is actively searching or not\ncurrentState = None\n\n    # ROUTE COLOURS - using Hue is more relable in most cases\n# colour that indicates a route\nrouteColour = Color.RED\n# colour that indicates a station\nstationColour = Color.BLUE\n\n    # METRICS\n# Used to determine speed from RPM\n# in inches, gets converted in equation\nwheelDiameter = 3.25 \n\n# Used to determine the upper and lower bounds in Station.CheckStationTime\ntimeThreshold = 0.1\n\n# Snapshot taken at the start of a journey\n# Used to determine time difference\ncoreSnapshot = None\n\n# ------------------------------------------\n# CLASSES\n# ------------------------------------------\n# -------------------\n#   Navigation\n# -------------------\n\n# Station is meant to represent the various locations around the residence of the user\n# Where PDR stops when delivering between rooms \nclass Station:\n    # all stations registered\n    allStations = []\n\n    def __init__(self, name, coordinates, timeDifference):\n        self.name = str(name)\n\n        # The Grid Coordinates in relation to base station\n        print(str(coordinates[0]) + \", \" + str(coordinates[1]))\n        self.coordinates = coordinates\n\n        # time taken in seconds to arrive at station from base station\n        self.timeDifference = round(timeDifference)\n        Station.allStations.append(self)\n    \n    # Used to compare snapshots in order to determine which station the PDR is at\n    @staticmethod\n    def CheckStationTime(thisSnapshot):\n        global stationColour\n        global currentStation\n        global goalStation\n        global coreSnapshot\n        global timeThreshold\n        global stationCounter\n        global originalStation\n        print(\"-------------------------------------------\")\n        print(\"Method: Station.CheckStationTime\")\n\n\n        currentValues = None\n\n        # get most recent snapshot\n        # calculate distance and time difference between it and the snapshot taken when the journey started\n        if isinstance(coreSnapshot, Snapshot):\n            currentValues = Snapshot.CalculateDistance(coreSnapshot,thisSnapshot)\n        else:\n            currentValues = Snapshot.CalculateDistance(Snapshot.allSnapshots[0],thisSnapshot)\n        currentCoords = Snapshot.CalculateGridPosition(currentValues[0], currentValues[1])\n\n        timeDifference = None\n        if isinstance(coreSnapshot, Snapshot):\n            timeDifference = Snapshot.CalculateTimeDifference(coreSnapshot, thisSnapshot)\n        else:\n            timeDifference = Snapshot.CalculateTimeDifference(Snapshot.allSnapshots[0], thisSnapshot)\n\n        # calculates the upper and lower bounds -> to account for small differences in time taken\n        timeUpper = timeDifference + (timeThreshold*60)\n        timeLower = timeDifference - (timeThreshold*60)\n\n        # finds stations where the time taken to get to the station is within the upper and lower bounds\n        relevantStations = []\n        for i in Station.allStations:\n            if i.timeDifference > timeLower and i.timeDifference < timeUpper:\n                relevantStations.append(i)\n\n        # if none found, and the PDR is over a statoin, it makes a new one\n        # this is how recalibration works\n        if len(relevantStations) == 0 and colour_sensor.color() == stationColour:\n            print(\"Make new Station\")\n            newStation = Station(str(len(Station.allStations)), currentCoords, timeDifference)\n            Snapshot.permanentSnapshots.append(Snapshot())\n\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1, 1)\n            brain.screen.print(\"New Station Made: \" + str(newStation.name))\n            brain.screen.next_row()\n            stationCounter += 1\n            return [False, newStation]\n\n        # if PDR is not over a station, something has gone wrong\n        elif len(relevantStations) == 0 and colour_sensor.color() != stationColour:\n            print(\"Not the correct colour -> no applicable stations\")\n            return [False, None]\n\n        # if a match found    \n        else:\n            print(\"found available station\")\n            currentStation = relevantStations[0]\n            if isinstance(currentStation, Station) == True and isinstance(goalStation, Station) == True:\n                if currentStation.name == goalStation.name:\n                    print(\"Found correct station\")\n                    brain.screen.clear_screen()\n                    brain.screen.set_cursor(1, 1)\n                    brain.screen.print(\"Found Goal!\")\n                    brain.screen.next_row()\n                    return [True, currentStation]\n            return [False]\n\n    # Used as an alternative to CheckStationTime\n    # Meant to count the stations as they are passed and check them \n    # to determine which station the PDR is currently at\n    @staticmethod\n    def CountStations():\n        global stationCounter\n        global goalStation\n        global originalStation\n        global currentStation\n        print(\"Count Stations\")\n\n        if stationCounter == 0:\n            print(\"Empty Counter\")\n            return [False]\n        \n        # get list of stations\n        # rearrange list\n            # take items in list before and including originalstation and move to end\n        # count through list, decreasing until counter is 0\n        # if this is goalStation, it worked!\n\n        frontList = Station.allStations[:Station.allStations.index(originalStation)+1]\n        backList = Station.allStations[Station.allStations.index(originalStation)+1:]\n        coreList = backList+frontList\n\n        # Gets the difference between the starting station and the goal in terms of stations passed\n        keyIndex = coreList.index(goalStation) - coreList.index(originalStation)\n\n        # excluding the first item in the list, compare the index between i and the starting station\n        # if it is equal to keyIndex, the PDR is currently at goalStation\n        for i in coreList[coreList.index(originalStation)+1:]:\n            basicIndex = coreList.index(i) - coreList.index(originalStation)\n            if basicIndex == keyIndex:\n                currentStation = goalStation\n                print(\"Match\")\n                return [True, currentStation]\n            print(\"No match\")\n        return [False]\n\n# Snapshot is save metrics for later comparision\nclass Snapshot:\n    allSnapshots = []\n\n    # permanentSnapshots are core instances that are saved through multiple uses\n    # e.g. Snapshots made when a station is mafe\n    permanentSnapshots = []\n\n    def __init__(self):\n        global wheelDiameter\n        print(\"Snapshot made\")\n        self.utime = round(time.time())\n        self.uvelocity = drivetrain.velocity(RPM)\n        self.uheading = drivetrain.heading(DEGREES)\n\n        # calculates speed from RPM\n        # 2pi * diameter of wheels/2 * RPM/60\n        # diameter of wheels is converted from inches to cm\n        self.speed = (2*math.pi)*((2.54*wheelDiameter)/2)*(self.uvelocity/60)\n        self.name = \"Snapshot\"+str(len(Snapshot.allSnapshots)+1)\n        print(\"added to list\")\n        Snapshot.allSnapshots.append(self)\n    \n    # Used to create a snapshot with specific values\n    # Used when reinstating snapshots after reading them from a file\n    @staticmethod\n    def SpecificSnapshot(nameValue, timeValue, velocityValue, headingValue, speedValue):\n        specificSnap = Snapshot()\n        specificSnap.utime = timeValue\n        specificSnap.uvelocity = velocityValue\n        specificSnap.uheading = headingValue\n        specificSnap.speed = speedValue\n        specificSnap.name = nameValue\n        return specificSnap\n\n    def DeleteSnapshot(self):\n        if self in Snapshot.allSnapshots:\n            Snapshot.allSnapshots.remove(self)\n        if self in Snapshot.permanentSnapshots:\n            Snapshot.permanentSnapshots.remove(self)\n        return\n\n\n    # Used to calculate the distance the PDR travelled between two snapshots\n    @staticmethod\n    def CalculateDistance(snapshotA, snapshotB):\n        # use the speed and time to calculate the distance between two points\n        # distance in cm\n        print(\"CalculateDistance\")\n        averageDistance = ((snapshotA.speed + snapshotB.speed)/2) * (snapshotB.utime-snapshotA.utime)\n        averageHeading = (snapshotA.uheading + snapshotB.uheading)/2\n        print(\"Distance: \" + str(averageDistance))\n        print(\"Heading: \" + str(averageHeading))\n\n        return [averageDistance, averageHeading]\n\n    # Used to estimate a basic grid position from the distance and heading given\n    # where base station is [0,0]\n    # This was supposed to provide another metric for comparison in case timing failed\n    @staticmethod\n    def CalculateGridPosition(averageDistance, averageHeading):\n        # uses the distance and heading to calculate the grid position relative to the base station\n        # using a right angled triangle\n        print(\"CalculateGridPosition\")\n        yValue = averageDistance*math.sin(averageHeading)\n        xValue = averageDistance*math.cos(averageHeading)\n        return [xValue,yValue]\n\n    # Used to calculate the difference between the time values of two snapshots\n    @staticmethod\n    def CalculateTimeDifference(snapshotA, snapshotB):\n        print(\"CalculateTimeDifference()\")\n        timeDifference = snapshotB.utime-snapshotA.utime\n        return timeDifference\n\n    # Alternative to CalculateGridPosition\n    # Was intended to calculate a grid position when taking velocity (rather than speed) into account\n    # As such, a direction could be given, which could help provide clarity when the PDR encounters looped systems\n    @staticmethod\n    def CalculateParityGridPosition():\n        # look through all of the snapshots in allsnapshots\n        # check heading\n        # if heading is same as last, ignore\n        # if heading is different to last, save snapshot in list\n        snaps = Snapshot.allSnapshots\n        keeperSnaps = [snaps[0]]\n        lastHeading = snaps[0].uheading\n        for i in snaps[1:]:\n            if i.uheading > (lastHeading+10) or i.uheading < (lastHeading-10):\n                keeperSnaps.append(i)\n                lastHeading = i.uheading\n\n        # for each pair in the keeperSnaps list\n        # determine a grid position between the two\n        # use the average heading to change the parity of either only the x, only the y, both, or neither\n        allXgrid = []\n        allYgrid = []\n        for i in keeperSnaps[1:]:\n            distanceResult = Snapshot.CalculateDistance(keeperSnaps[keeperSnaps.index(i)-1],i)\n            gridPosResult = Snapshot.CalculateGridPosition(distanceResult[0], distanceResult[1])\n            if distanceResult[-1] > 180:\n                gridPosResult[1] *= -1\n            if distanceResult[-1] > 90 and distanceResult[-1] <= 270:\n                gridPosResult[0] *= -1\n            allXgrid.append(gridPosResult[0])\n            allYgrid.append(gridPosResult[1])\n\n        # get the sum of the values\n        finalCoords = [sum(allXgrid), sum(allYgrid)]\n        \n        return finalCoords\n        \n\n\n# -------------------\n#   Display\n# -------------------\n\n# Used to manage the main menu on brain.screen\ndef ShowDisplay():\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Left - Add Station\")\n    brain.screen.next_row()\n    brain.screen.print(\"Check - Toggle Lid\")\n    brain.screen.next_row()\n    brain.screen.print(\"Right - Choose Station\")\n    brain.screen.next_row()\n    buttonPressed = False\n    while buttonPressed == False:\n        if brain.buttonLeft.pressing():\n            print(\"Recalibrate Stations\")\n            RecalibrateStations()\n            buttonPressed = True\n        elif brain.buttonRight.pressing():\n            print(\"ChooseWhere to move()\")\n            ChooseWhereToMove()\n            buttonPressed = True\n    return\n\n# ------------------------------------------\n# EVENTS\n# ------------------------------------------\n# Class to represent the different states of the PDR\nclass StateMachine():\n    Listening = 0\n    Moving = 1\n\n# Class to track and manage the state machine\ndef StateMachineChanged():\n    global goalStation\n    global currentStation\n    global currentState\n    \n\n    print(\"StateMachineChanged Called\")\n\n    if currentState == StateMachine.Listening:\n        print(\"\\nListeningStateActivated\")\n        drivetrain.stop()\n        brain.screen.clear_screen()\n\n        if goalStation == None:\n            currentStation = Station.allStations[0]\n        else:\n            if isinstance(goalStation, Station) == True:\n                currentStation = goalStation\n            else:\n                currentStation = Station.allStations[0]\n        print(\"ShowDisplay()\")\n        ShowDisplay()\n        return\n\n    elif currentState == StateMachine.Moving:\n        print(\"\\nMovingStateActivated\")\n\n        # Identifies missing required values and informs user\n        if isinstance(currentStation, Station) == False or isinstance(goalStation, Station) == False:\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1, 1)\n            brain.screen.print(\"Insufficent information.\")\n            brain.screen.next_row()\n            if isinstance(currentStation, Station) == True:\n                brain.screen.print(\"Starting Position: \" + str(currentStation.name))\n                brain.screen.next_row()\n            else:\n                brain.screen.print(\"Unsuitable Starting Position\")\n                brain.screen.next_row()\n                brain.screen.print(\"Please recalibrate the PDR.\")\n                brain.screen.next_row()\n            if isinstance(goalStation, Station) == True:\n                brain.screen.print(\"Ending Position: \" + str(goalStation.name))\n                brain.screen.next_row()\n            else:\n                brain.screen.print(\"Unsuitable Ending Position\")\n                brain.screen.next_row()\n                brain.screen.print(\"Please select another ending position from the screen.\")\n                brain.screen.next_row()\n            while brain.buttonCheck.pressing() == False:\n                wait(5, MSEC)\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1, 1)\n            currentState = StateMachine.Listening\n            return\n\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Currently Moving.\")\n        brain.screen.next_row()\n        brain.screen.print(\"Please leave me alone.\")\n\n        MovementController(1,None)\n    return        \n\n\n# ------------------------------------------\n# FUNCTIONS\n# ------------------------------------------\n\n# Used to initally calibrate the PDR, by assigning it a base station\ndef CalibrateBase():\n    global currentStation \n    if len(Station.allStations) == 0:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"PDR is not calibrated\")\n        brain.screen.next_row()\n        brain.screen.print(\"Please set PDR atop\")\n        brain.screen.next_row()\n        brain.screen.print(\"of the Station the \")\n        brain.screen.next_row()\n        brain.screen.print(\"user wishes to use\")\n        brain.screen.next_row()\n        brain.screen.print(\"as a baseline.\")\n        brain.screen.next_row()\n    while len(Station.allStations) == 0:\n        if colour_sensor.is_near_object():\n            if colour_sensor.color() == stationColour:\n                currentStation = Station(\"Base\", [0,0], 0)\n                \n    if len(Snapshot.allSnapshots) == 0:\n        thisSnapshot = Snapshot()\n        Snapshot.permanentSnapshots.append(thisSnapshot)\n    else:\n        Snapshot.allSnapshots[0] = Snapshot()\n        Snapshot.permanentSnapshots.append(Snapshot.allSnapshots[0])\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"PDR has been calibrated\")\n    wait(5,SECONDS)\n    brain.screen.clear_screen()\n    # everything is calculated relative to this station\n    return\n\n\n# START\ndef powerOn():\n    \n    global currentStation\n\n    print(\"at powerOn\")\n    drivetrain.set_stopping(BRAKE)\n    drivetrain.set_stopping(HOLD)\n    brain.screen.set_font(FontType.MONO12)\n\n    # File management\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Please insert sdcard\")\n    \n    while brain.sdcard.is_inserted() != True:\n        wait(5,MSEC)\n    brain.screen.clear_screen()\n    ReadStationDataByte()\n    ReadSnapshotDataByte()\n    ReadGeneralDataByte()\n\n\n    CalibrateBase()\n    drivetrain.turn_to_heading(0, DEGREES,wait=True)\n\n    # If currentStation has not been assigned to a station, and an initial snapshot has been taken\n    # this indicates that while the base station has been created, it hasn't been assigned to the currentStation\n    # variable yet\n    if isinstance(currentStation, Station) != True and len(Snapshot.allSnapshots) == 1:\n        currentStation = Station.allStations[0]\n\n    # If no currentStation and multiple snapshots\n    # This indicates that the PDR has been used for a while and there was potentially an uncaught error when accessing files\n    # As the data was not read correctly\n    elif isinstance(currentStation, Station) != True and len(Snapshot.allSnapshots) > 1:\n        # The most recent snapshot is used to try to find a station\n        # It is compared to the first snapshot and the distance is calculated\n        result = Station.CheckStationTime(Snapshot.allSnapshots[-1])\n\n        # If unable to find a station\n        # asks the user to help\n        if len(result) == 1:\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1, 1)\n            brain.screen.print(\"Unable to orient self.\")\n            brain.screen.next_row()\n            brain.screen.print(\"Please bring me back \")\n            brain.screen.next_row()\n            brain.screen.print(\"to origin station.\")\n            brain.screen.next_row()\n            originStation = Station.allStations[0]\n            while colour_sensor.color() != stationColour:\n                wait(1,SECONDS)                \n                if colour_sensor.color() == stationColour and brain_inertial.orientation(OrientationType.YAW, DEGREES) == 0:\n                    drivetrain.turn_to_heading(0, DEGREES)\n                    break\n\n            print(\"Calibrate Base again\")\n            CalibrateBase()\n            currentStation = Station.allStations[0]\n        \n        # if able to find original currentstation\n        elif result[0] == False and isinstance(result[-1], Station) == True:\n            currentStation = result[-1]\n\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1,1)\n    brain.screen.print(\"Hello!\")\n    wait(3,SECONDS)\n    brain.screen.clear_screen()\n    print(\"finished powerOn\")\n    return\n\n\n# STOP\ndef powerOff():\n    print(\"powerOff()\")\n    drivetrain.stop()\n\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Please insert sdcard\")\n    \n    while brain.sdcard.is_inserted() != True:\n        wait(5,MSEC)\n\n    # Writes data to the sdcard\n    WriteStationDataByte()\n    WriteSnapshotDataByte()\n    WriteGeneralDataByte()\n    \n    brain.screen.clear_screen()\n    brain.screen.print(\"Goodbye!\")\n    wait(5,SECONDS)\n    brain.screen.clear_screen()\n\n    brain.program_stop()\n    return\n\n#\n\n# -------------------\n#   Movement and Evasion\n# -------------------\n\n# Determines which methods to use and the parameters\n# The type parameter is used to identify the reasoning behind calling the function\n# 0 - For recalibration\n# 1 - For searching for a route initially\ndef MovementController(type, estimatedStations):\n    global originalStation\n    global currentStation\n    global stationCounter\n\n    originalStation = currentStation\n    stationCounter = 0\n\n    print(\"MovementController\")\n    while True:\n        if type == 0:\n            result = SearchFor(type,estimatedStations)\n            if result <= 0:\n                return result\n            else:\n                wait(5,SECONDS)\n                estimatedStations -= 1\n        elif type == 1:\n            result = SearchFor(type,None)\n            if result == \"Error\":\n                print(\"Error\")\n                return\n            elif result == True:\n                print(\"Goal station found\")\n                return\n\n# Follows Routes when recalibrating\ndef MoveAlong(estimatedStations):\n    global currentStation\n    global currentState\n    global coreSnapshot\n\n    print(\"MoveAlong\")\n    print(str(estimatedStations))\n\n    coreSnapshot = Snapshot()\n    foundStationBool = False\n \n    while foundStationBool != True:\n        # Moves forward while detecting a route\n        while (colour_sensor.hue() <= 359 and colour_sensor.hue() >= 235) or (colour_sensor.hue() >= 0 and colour_sensor.hue() <= 10):\n            drivetrain.drive(FORWARD)\n        drivetrain.stop()\n        wait(20,MSEC)\n        print(\"RouteColour not detected\")\n\n        # If blue has been detected\n        if colour_sensor.hue() < 235 and colour_sensor.hue() >= 215: \n            drivetrain.stop()\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1,1)\n            brain.screen.print(\"Found Station!\")\n            brain.screen.next_row()\n            brain.screen.print(\"Please wait...\")\n            brain.screen.next_row()\n            thisSnapshot = Snapshot()\n\n            # Checks the time taken to get to the station, using thisSnapshot as a comparison point\n            foundStation = Station.CheckStationTime(thisSnapshot)\n\n            if len(foundStation) > 1 and isinstance(foundStation[1],Station) == True :\n                print(\"Station found\")\n                estimatedStations -=1\n                print(str(estimatedStations))\n            \n            # If all of the expected stations have been accounted for\n            if estimatedStations <= 0:\n                if estimatedStations < 0:\n                    estimatedStations = 0\n                brain.screen.clear_screen()\n                brain.screen.set_cursor(1, 1)\n                brain.screen.print(\"Found all available\")\n                brain.screen.next_row()\n                brain.screen.print(\" stations\")\n                brain.screen.next_row()\n                print(\"Found all available stations\")\n                wait(2,SECONDS)\n                brain.screen.clear_screen()\n            else:\n                # Moves forward slightly to help center the PDR over the station\n                print(\"Move forward small\")\n                drivetrain.drive_for(FORWARD, 20, MM,wait=True)\n\n                # This is to help provide enough of a time difference between stations \n                # so that they can be easily identifiable later\n                wait(7,SECONDS)\n            return estimatedStations\n        else:\n            SearchFor(2,None)\n    return estimatedStations\n\n# Searches for a Route when one is not detected\n# The type parameter is used to identify the reasoning behind calling the function\n# 0 - For recalibration\n# 1 - For searching for a route initially\n# 2 - For course correcting\ndef SearchFor(type,estimatedStations):\n    global routeColour\n    global stationColour\n\n    print(\"Search For\")\n\n    # To help stop recursion, returns if \"estimatedStations\" = 0:\n    # This happens when the PDR is recalibrated, and used to catch when all the stations have been found \n    # if this has somehow been previously missed\n    if isinstance(estimatedStations,int):\n        if estimatedStations <= 0:\n            estimatedStations = 0\n            return estimatedStations\n\n    #directions = [0,30,60,90,120,150,180,210,240,270,300,330]\n    #directions = [0,45,90,135,180,225,270,315]\n    directions = [0,90,180,270]\n\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1,1)\n    brain.screen.print(\"Looking for Route...\")\n    brain.screen.next_row()\n\n    if type != 2:\n        drivetrain.turn_to_heading(0, DEGREES,wait=True)     \n\n    for i in directions:\n        canContinue = True\n        if type != 2:\n            drivetrain.turn_to_heading(i, DEGREES,wait=True)\n        drivetrain.set_rotation(0, DEGREES)\n        drivetrain.drive_for(FORWARD, 40, MM,wait=True)\n\n        while canContinue == True:\n            currentHue = colour_sensor.hue()\n            # If the colour sensed is red or blue\n            if (currentHue >= 340 and currentHue <= 359) or (currentHue >= 0 and currentHue <= 10) or ( currentHue <= 290 and currentHue >= 235):\n                # If the colour is blue, therefore a station is found\n                if (currentHue <= 290 and currentHue >= 235):\n                    print(\"found station\")\n                    drivetrain.stop()\n                    if type == 0:\n                        result = MoveAlong(estimatedStations)\n                        return result\n                    elif type == 1:\n                        result = MoveAlongTape()\n                        return result\n                    elif type == 2:\n                        return \"blue\"\n                # If the colour is red, therefore a route is found\n                elif (currentHue >= 340 and currentHue <= 359) or (currentHue >= 0 and currentHue <= 10):\n                    print(\"found route\")\n                    brain.screen.clear_screen()\n                    brain.screen.set_cursor(1,1)\n                    brain.screen.print(\"Found Route!\")\n                    brain.screen.next_row()\n                    if type == 0:\n                        result = MoveAlong(estimatedStations)\n                    elif type == 1:\n                        result = MoveAlongTape()\n                    elif type == 2:\n                        return None\n                    print(result)\n                    return result\n\n            # If the optical sensor has not been able to detect red nor blue\n            else:\n                # This is where most of the orientation for the scanning is done\n                # The drive train will rotation 360 degrees to the North, South, East, and West of the base station\n                if drivetrain.rotation(DEGREES) >= 359:\n                    # move backwards, turn 90d right, try again\n                    print(\"Full Circle Completed\")\n                    drivetrain.turn_to_heading(i, DEGREES,wait=True)\n                    print(\"Going back\")\n                    drivetrain.drive_for(REVERSE, 40, MM,wait=True)\n                    \n                    canContinue = False\n                else:\n                    # Turn 5 degrees to the right\n                    drivetrain.turn_for(RIGHT,5,DEGREES,wait=True)\n\n    # if unable to find any red or blue at all\n    # alert the user\n    drivetrain.turn_to_heading(0, DEGREES,wait=True)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Unable to find connection.\")\n    wait(10,SECONDS)\n    brain.screen.clear_screen()\n    return -1\n\n    \n# Follows Routes when delivering an object\ndef MoveAlongTape():\n    global currentStation\n    global currentState\n    global goalStation\n    \n    global stationCounter\n\n    print(\"MoveAlongTape\")\n\n    coreSnapshot = Snapshot()\n    foundStationBool = False\n    returnResult = \"\"\n \n    while foundStationBool != True:\n        # Checks that the robot can still detect the correct colours, and therefore, is still following the line\n        # Hues between 359 and 245, and 0 and 10 are all interpted as red\n        while (colour_sensor.hue() <= 359 and colour_sensor.hue() >= 245) or (colour_sensor.hue() >= 0 and colour_sensor.hue() <= 10):\n            drivetrain.drive(FORWARD)\n\n        print(\"Stopping DriveTrain\")\n        drivetrain.stop()\n        wait(20,MSEC)\n        print(\"RouteColour not detected\")\n\n        # Checks the hure the robot is currently sensing\n        # Hues between 245 and 210 are interpreted as blue\n            #   The colour of the tape used is approx. 224\n        # This also allows for transitions between the red tape and the blue station to be taken into consideration\n        if (colour_sensor.hue() < 245 and colour_sensor.hue() >= 210) or returnResult == \"blue\":\n            brain.screen.clear_screen()\n            brain.screen.set_cursor(1,1)\n            brain.screen.print(\"Found Station!\")\n            brain.screen.next_row()\n            brain.screen.print(\"Please wait...\")\n            brain.screen.next_row()\n\n            thisSnapshot = Snapshot()\n            # returns a list\n\n            # Initially, this was supposted to use time to detemine the station\n            # But without more sensors, there was too much variation and uncertainty to use\n            # the time taken to get to a station for comparison\n            # So we use CountStation instead\n            foundStation = Station.CountStations()\n\n            if len(foundStation) == 1:\n                # foundStation only returned False\n                return False\n            elif len(foundStation) > 1:\n                print(\"Goal Station found\")\n                Snapshot.permanentSnapshots.append(thisSnapshot)\n                currentStation = foundStation[-1]\n                goalStation = -1\n                stationCounter = 0\n                currentState = StateMachine.Listening\n                return True\n            else:\n                print(\"Error, Stop Searching\")\n                return \"Error\"\n        else:\n            returnResult = SearchFor(2,None)\n\n\n# -------------------    \n#   Files\n# -------------------\n\n# The following functions and variables are all about file manipulation, \n# more specifically, reading and writing key information onto the microSD card\n# the brain has access to.\n\n# name of csv files\nfileName = \"myData.csv\"\nstationFileName = \"myStations.csv\"\nsnapshotFileName = \"mySnapshots.csv\"\n\n# BYTE DATAHANDLING\n# Writes registered stations and snapshots onto files, as well as general information\ndef WriteStationDataByte():\n    global stationFileName\n\n    # Preparation:\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Please wait...\")\n    print(\"Please wait...\")\n\n    # Checks file exists\n    if brain.sdcard.exists(stationFileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        brain.screen.print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    # Prepare data:\n    # Preparing fields for the CSV file\n    headerText = \"name, xcoord, ycoord, timeDifference\"\n    dataBuffer = headerText + \"\\n\"\n    for i in Station.allStations:\n        dataBuffer += \"%s\"%i.name + \",\"\n        dataBuffer += \"%s\"%str(i.coordinates[0]) + \",\"\n        dataBuffer += \"%s\"%str(i.coordinates[1]) + \",\"\n        dataBuffer += \"%s\"%str(i.timeDifference) + \"\\n\"\n        \n        \n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n\n    # saves file, then checks the file size to ensure it has saved properly\n    brain.sdcard.savefile(stationFileName, bytearray(dataBuffer, 'utf-8'))\n    if brain.sdcard.size(stationFileName) == 0:\n        print(\"Error Occured: Data not saved.\")\n    else:\n        print(\"Data Saved\")\n    wait(5, SECONDS)\n    return\n\ndef WriteGeneralDataByte():\n    global fileName\n    global currentStation\n    # Preparation\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Please wait...\")\n\n    if brain.sdcard.exists(fileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    headerText = \"name, stationName\"\n    dataBuffer = headerText + \"\\n\"\n    dataBuffer += \"currentStation, %s\"%currentStation.name + \"\\n\"\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n\n    if brain.sdcard.savefile(fileName, bytearray(dataBuffer, 'utf-8')) == 0:\n        print(\"Error Occured: Data not saved.\")\n    else:\n        print(\"Data Saved\")\n    wait(5, SECONDS)\n    return\n\n\n\ndef WriteSnapshotDataByte():\n    global snapshotFileName\n    # Preparation\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Please wait...\")\n\n    if brain.sdcard.exists(snapshotFileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    # Prepare data\n    headerText = \"name, time, velocity, heading, speed\"\n    dataBuffer = headerText + \"\\n\"\n    for i in Snapshot.permanentSnapshots:\n        dataBuffer += \"%s\"%i.name + \",\"\n        dataBuffer += \"%s\"%str(i.utime) + \",\"\n        dataBuffer += \"%s\"%str(i.uvelocity) + \",\"\n        dataBuffer += \"%s\"%str(i.uheading) + \",\"\n        dataBuffer += \"%s\"%str(i.speed) + \"\\n\"\n        \n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n\n    if brain.sdcard.savefile(snapshotFileName, bytearray(dataBuffer, 'utf-8')) == 0:\n        print(\"Error Occured: Data not saved.\")\n    else:\n        print(\"Data Saved\")\n    wait(5, SECONDS)\n    return\n\n\n\n# READ FROM BYTE\n# Reads past stations and snapshots on files, and reinstates them as part of the system\ndef ReadStationDataByte():\n    global stationFileName\n    # Preparation\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Please wait...\")\n\n    if brain.sdcard.exists(stationFileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    # Checks the size of the file before querying\n    if brain.sdcard.filesize(stationFileName) == 0:\n        print(\"Error Occured: File Empty.\")\n        return False\n    \n    rawData = brain.sdcard.loadfile(stationFileName)\n\n    # The following code splits the raw data into subgroups of length 4, \n    # removes the headers, and uses the rest to rebuild class instances\n    \n    # Source - https://stackoverflow.com/a/60982598\n    # Posted by Aplet123\n    # Retrieved 2026-04-13, License - CC BY-SA 4.0\n    actualData = [x.decode(encoding=\"utf-8\") for x in rawData.split(b\"\\x00\") if len(x)]\n\n    subgroupList = [actualData[i:i + 4] for i in range(0, len(actualData), 4)]\n    del subgroupList[0]\n    for i in subgroupList:\n        StationFromCSV(i)\n    \n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Saved Stations Reinstated!\")\n    wait(5,SECONDS)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    return\n\n\ndef ReadSnapshotDataByte():\n    global snapshotFileName\n    # Preparation\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Please wait...\")\n\n    if brain.sdcard.exists(snapshotFileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    if brain.sdcard.filesize(snapshotFileName) == 0:\n        print(\"Error Occured: File Empty.\")\n        return False\n    \n    rawData = brain.sdcard.loadfile(snapshotFileName)\n\n    # The following code splits the raw data into subgroups of length 4, \n    # removes the headers, and uses the rest to rebuild class instances\n    \n    # Source - https://stackoverflow.com/a/60982598\n    # Posted by Aplet123\n    # Retrieved 2026-04-13, License - CC BY-SA 4.0\n    actualData = [x.decode(encoding=\"utf-8\") for x in rawData.split(b\"\\x00\") if len(x)]\n    \n    if len(actualData) == 0:\n        print(\"Error Occured: Data not saved.\")\n        return False\n\n    subgroupList = [actualData[i:i + 5] for i in range(0, len(actualData), 5)]\n    del subgroupList[0]\n    for i in subgroupList:\n        SnapshotFromCSV(i)\n    \n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Saved Snapshots Reinstated!\")\n    wait(5,SECONDS)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    return\n\n\n\ndef ReadGeneralDataByte():\n    global fileName\n    global currentStation\n    # Preparation\n    if brain.sdcard.is_inserted() != True:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        print(\"Please insert microSD card.\")\n    while brain.sdcard.is_inserted() != True:\n        wait(5, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Please wait...\")\n\n    if brain.sdcard.exists(fileName) == False:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)   \n        print(\"Error Occured: Data not saved.\")\n        wait(5, SECONDS)\n        return\n\n    if brain.sdcard.filesize(fileName) == 0:\n        print(\"Error Occured: File Empty.\")\n        return False\n    \n    #byte array\n    rawData = brain.sdcard.loadfile(fileName)\n\n    # The following code converts the byte array into a list\n    \n    # Source - https://stackoverflow.com/a/60982598\n    # Posted by Aplet123\n    # Retrieved 2026-04-13, License - CC BY-SA 4.0\n    actualData = [x.decode(encoding=\"utf-8\") for x in rawData.split(b\"\\x00\") if len(x)]\n    \n    if len(actualData) == 0:\n        print(\"Error Occured: Data not saved.\")\n        return False\n\n\n    # Collects all stations that match the name of the currentStationName variable into one list, \n    # then assigns the first in the list to \"presentStation\"\n    currentStationName = actualData[-1]\n    presentStation = list(filter(lambda x: x.name.lower() == currentStationName.lower(), Station.allStations))[0]\n    if isinstance(presentStation, Station):\n        currentStation = presentStation \n    \n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    print(\"Saved Rooms Reinstated!\")\n    wait(5,SECONDS)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    return\n\n# CSV TO CLASS\n# Converts CSV file data to an instance of the Station class\ndef StationFromCSV(oneRow):\n    coords = [int(oneRow[1]),int(oneRow[2])]\n    return Station(oneRow[0], coords, int(oneRow[3]))\n\n# Converts CSV file data to an instance of the Snapshot class\ndef SnapshotFromCSV(oneRow):\n    return Snapshot.SpecificSnapshot(oneRow[0], int(oneRow[1]), int(oneRow[2]), int(oneRow[3]),  int(oneRow[4]))\n\n    \n\n\n\n\n\n# -------------------    \n#   Display Navigation\n# -------------------\n\n# The PDR recalibrates the system by essentually wiping it all and starting again\ndef RecalibrateStations(): \n    print(\"RecalibrateStations()\")\n    global goalStation\n    global stationColour\n    global currentStation\n    \n\n    counter = 0\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Please enter the \")\n    brain.screen.next_row()\n    brain.screen.print(\"number of Stations added\")\n    brain.screen.next_row()\n    brain.screen.print(\"Press check when done\")\n    brain.screen.next_row()\n    brain.screen.print(\"Total stations: \" + str(counter))\n\n    stillGoing = True\n\n    # Determining what number of stations in total\n    # Specifically what number of stations should the PDR look for\n    while stillGoing == True:\n        brain.screen.clear_row(brain.screen.row())\n        brain.screen.set_cursor(brain.screen.row(), 1)\n        brain.screen.print(\"Total stations: \" + str(counter))\n        if brain.buttonLeft.pressing():\n            if counter > 0:\n                counter -= 1\n        elif brain.buttonRight.pressing():\n            counter += 1\n        elif brain.buttonCheck.pressing():\n            stillGoing = False\n        wait(60,MSEC)\n\n    # Setting a new base\n    if currentStation != Station.allStations[0]:\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Please set PDR atop\")\n        brain.screen.next_row()\n        brain.screen.print(\"of the Station the \")\n        brain.screen.next_row()\n        brain.screen.print(\"user wishes to use\")\n        brain.screen.next_row()\n        brain.screen.print(\"as a baseline.\")\n        brain.screen.next_row()\n    \n    Station.allStations = []\n\n    while len(Station.allStations) == 0:\n        if colour_sensor.color() == stationColour:\n            currentStation = Station(\"Base\",[0,0], 0)\n            Snapshot.permanentSnapshots.append(Snapshot())\n        wait(5,MSEC)\n\n    # Moves the robot -> this leads to both the searching and the moving algorithsm \n    result = MovementController(0, counter)\n\n    currentStation = Station.allStations[-1]\n    return\n\n\n# Determines the station that the PDR will move to\ndef ChooseWhereToMove():\n    global goalStation\n    global currentState\n\n    print(\"ChooseWhereToMove\")\n\n    brain.screen.clear_screen()\n    brain.screen.set_font(FontType.MONO12)\n    brain.screen.set_cursor(1,1)\n\n    # checks if there are suitable number of stations available\n    if len(Station.allStations) <= 1:\n        print(\"There is nowhere to go\")\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"There is nowhere to go\")\n        brain.screen.next_row()\n        wait(3,SECONDS)\n        return\n    \n    index = 0\n    selected = False\n\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Please choose which station\")\n    brain.screen.next_row()\n    brain.screen.print(\"the PDR should move to\")\n    brain.screen.next_row()\n    wait(5,SECONDS)\n\n    print(\"Select station\")\n    while selected == False:\n        # Displays names of stations on the screen to allow users to choose\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1,1)\n        brain.screen.print(\"Station: \" + str(Station.allStations[index].name))\n\n        if brain.buttonRight.pressing():\n            # when the user presses the right button on the brain, it will increase the index variable...\n            if (index + 1) > len(Station.allStations)-1:\n                index = 0\n            else:\n                index += 1\n        elif brain.buttonLeft.pressing():\n            if (index - 1) < 0:\n                index = len(Station.allStations)-1\n            else:\n                index -= 1\n        elif brain.buttonCheck.pressing():\n            # ...where the index value is used to choose a station\n            if index-1>len(Station.allStations):\n                return\n\n            goalStation = Station.allStations[index]\n\n            # currentState is changed\n            currentState = StateMachine.Moving\n            selected = True\n        wait(60,MSEC)\n    return\n\n\n\n\n\n\n\n\n\n\n\n# ------------------------------------------\n# MAIN\n# ------------------------------------------\n\ndef main():\n    global currentState\n    powerOn()\n    currentState = StateMachine.Listening\n\n    drivetrain.set_drive_velocity(27, RPM)\n    drivetrain.set_turn_velocity(50, RPM)\n\n    while True:\n        StateMachineChanged()\n        wait(20,MSEC)\n\n    return  \n\nmain()","textLanguage":"python","robotConfig":[{"port":[6,10,null],"name":"drivetrain","customName":false,"deviceType":"Drivetrain","deviceClass":"smartdrive","setting":{"type":"2-motor","wheelSize":"wheel325in","gearRatio":"1:1","direction":"fwd","gyroType":"integrated","width":"295","unit":"mm","wheelbase":"40","wheelbaseUnit":"mm","xOffset":"0","xOffsetUnit":"mm","yOffset":"0","yOffsetUnit":"mm","thetaOffset":"180"},"triportSourcePort":null},{"port":[8],"name":"colour_sensor","customName":true,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22}],"slot":5,"platform":"EXP","sdkVersion":"20240802.15.00.00","appVersion":"4.64.0","fileFormat":"2.0.0","targetBrainGen":"First","v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}